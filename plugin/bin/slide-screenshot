#!/usr/bin/env node

const path = require('path');
const fs = require('fs');

const filePath = process.argv[2];
if (!filePath) {
  console.error('Usage: slide-screenshot <html-file>');
  process.exit(1);
}

const absPath = path.resolve(filePath);
if (!fs.existsSync(absPath)) {
  console.error(`File not found: ${absPath}`);
  process.exit(1);
}

let puppeteer;

function tryRequire(name) {
  const dirs = [
    process.env.CLAUDE_PLUGIN_DATA,
    path.join(__dirname, '..'),
  ].filter(Boolean);
  for (const dir of dirs) {
    try { return require(path.join(dir, 'node_modules', name)); } catch {}
  }
  try { return require(name); } catch {}
  return null;
}

puppeteer = tryRequire('puppeteer');

if (!puppeteer) {
  const installDir = process.env.CLAUDE_PLUGIN_DATA || path.join(__dirname, '..');
  console.error('puppeteer not found. Installing...');
  try {
    fs.mkdirSync(installDir, { recursive: true });
    // Safe: all arguments are hardcoded, no user input
    require('child_process').execFileSync(
      'npm', ['install', '--no-save', 'puppeteer'],
      { cwd: installDir, stdio: 'inherit', timeout: 120000 },
    );
    puppeteer = tryRequire('puppeteer');
  } catch {}
}

if (!puppeteer) {
  console.error('Failed to install puppeteer.');
  process.exit(1);
}

(async () => {
  const outDir = path.join(path.dirname(absPath), '.screenshots');
  fs.mkdirSync(outDir, { recursive: true });

  const browser = await puppeteer.launch({ headless: true });
  const page = await browser.newPage();

  // s-slide is 297mm x 167mm ≈ 1123px x 631px at 96dpi
  // Use a wider viewport to ensure full slide is visible
  await page.setViewport({ width: 1400, height: 900 });

  await page.goto(`file://${absPath}`, {
    waitUntil: 'networkidle2',
    timeout: 20000,
  });

  // Wait a bit for Tailwind CDN to apply styles
  await new Promise((r) => setTimeout(r, 1000));

  // Hide the toolbar so it doesn't appear in screenshots
  await page.evaluate(() => {
    const toolbar = document.querySelector('s-deck')?.nextElementSibling;
    if (toolbar) toolbar.style.display = 'none';
  });

  const slides = await page.$$('s-slide');

  for (let i = 0; i < slides.length; i++) {
    const outPath = path.join(outDir, `slide-${i + 1}.png`);
    await slides[i].screenshot({ path: outPath });
    console.log(outPath);
  }

  await browser.close();
})();
