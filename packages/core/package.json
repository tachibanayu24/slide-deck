{
  "name": "@tachibanayu24/slide-deck",
  "version": "0.2.0",
  "description": "Web Components framework for HTML slide decks — LLM-friendly, PDF-ready",
  "type": "module",
  "main": "dist/slide-deck.js",
  "exports": {
    ".": "./dist/slide-deck.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=iife --outfile=dist/slide-deck.js --minify",
    "dev": "esbuild src/index.ts --bundle --format=iife --outfile=dist/slide-deck.js --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tachibanayu24/slide-deck.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/tachibanayu24/slide-deck",
  "bugs": "https://github.com/tachibanayu24/slide-deck/issues",
  "keywords": ["slides", "presentation", "web-components", "pdf", "tailwind"],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  }
}
